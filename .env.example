# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

FLORA_API_KEY=your_flora_api_key_here

# ImageKit — free at imagekit.io, used to host reference images for Flora
# Find in: ImageKit dashboard → Developer Options → API keys
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Portkey — Xero's internal LLM gateway for Claude
# Find in: Portkey → Test → Shared Team Workspace → API Keys
PORTKEY_API_KEY=your_portkey_api_key_here
